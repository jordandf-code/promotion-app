# Backend environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to Git.

# PostgreSQL connection string from Supabase
# Found in: Supabase dashboard → Project → Settings → Database → Connection string (URI)
# Use the "dev" project locally, "prod" project in Render
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Secret used to sign JWT tokens — any long random string works
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must match the value set in Render for production
JWT_SECRET=replace-with-a-long-random-secret

# Port the Express server listens on (optional — defaults to 3001)
# PORT=3001

# Resend API key for email notifications (weekly digest, feedback alerts)
# Sign up at resend.com, create an API key, and paste it here.
# The from-address is configured by the superuser in Super Admin → Platform.
# RESEND_API_KEY=re_xxxxxxxxxxxx

# App URL used in email CTA buttons (defaults to https://partner.jordandf.com)
# APP_URL=https://partner.jordandf.com

# ---------------------------------------------------------------------------
# NOT HERE: Anthropic API key
# ---------------------------------------------------------------------------
# Each user enters their own Anthropic API key in the Admin tab of the app.
# It is stored in the database per user and read at call time by the backend.
# Do not add ANTHROPIC_API_KEY here — it would be a shared key and is not how
# this app is designed.
# ---------------------------------------------------------------------------
