# Frontend environment variables (Vite)
# Copy this file to .env and fill in your values.
# Never commit .env to Git.
# All variables must start with VITE_ to be accessible in the browser bundle.

# URL of the backend Express server
# Local development: http://localhost:3001
# Production (Render): set this to your Render service URL in the Vercel dashboard
VITE_API_URL=http://localhost:3001

# ---------------------------------------------------------------------------
# NOT HERE: Anthropic API key
# ---------------------------------------------------------------------------
# The Anthropic API key is stored per user in the database and proxied through
# the backend. It is never exposed to the frontend bundle or env vars.
# ---------------------------------------------------------------------------
